{
  "version": 2,
  "builds": [
    {
      "src": "index.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "index.js"
    }
  ],
  "env": {
    "HABITICA_USER_ID": "@habitica-user-id",
    "HABITICA_API_TOKEN": "@habitica-api-token"
  },
  "build": {
    "env": {
      "NODE_ENV": "production"
    }
  },
  "functions": {
    "index.js": {
      "memory": 1024,
      "maxDuration": 10
    }
  }
}
